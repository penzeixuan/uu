local function getRandomMessage(messageType)
    local messages = KillSayMessages[messageType]
    if not messages or #messages == 0 then return nil end
    return messages[math.random(1, #messages)]
end

local function formatMessage(message, victimName, killerName, weaponName)
    local formatted = message
    formatted = formatted:gsub("%%Died%%", victimName or "target")
    formatted = formatted:gsub("%%Killer%%", killerName or LocalPlayer.Name)
    formatted = formatted:gsub("%%Weapon%%", weaponName or "weapon")
    formatted = formatted:gsub("%%XP%%", tostring(math.random(50, 500)))
    formatted = formatted:gsub("%%Credits%%", tostring(math.random(100, 1000)))
    return formatted
end

local function sendKillSayMessage(messageType, victimName)
    local currentTime = tick()
    if currentTime - KillSayData.lastKillTime < KillSayData.killCooldown then
        return
    end
    KillSayData.lastKillTime = currentTime
    
    local message = getRandomMessage(messageType)
    if message then
        local formattedMessage = formatMessage(message, victimName, nil, nil)
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(formattedMessage, "All")
    end
end

local function setupKillSayListeners()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                local lastHealth = humanoid.Health
                humanoid.HealthChanged:Connect(function(newHealth)
                    if newHealth <= 0 and lastHealth > 0 then
                        if Enabled.KillSay then
                            local assistPlayers = {}
                            
                            for _, p in pairs(Players:GetPlayers()) do
                                if p ~= LocalPlayer and p ~= player and p.Character then
                                    local dist = (player.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                                    if dist < 30 then
                                        table.insert(assistPlayers, p)
                                    end
                                end
                            end
                            
                            if #assistPlayers > 0 and Enabled.KillSayAssist then
                                sendKillSayMessage("Assist", player.Name)
                            elseif Enabled.KillSayFinish then
                                sendKillSayMessage("Finish", player.Name)
                            elseif Enabled.KillSay then
                                sendKillSayMessage("Normal", player.Name)
                            end
                        end
                    end
                    lastHealth = newHealth
                end)
            end
        end
    end
    
    Players.PlayerAdded:Connect(function(player)
        if player ~= LocalPlayer then
            player.CharacterAdded:Connect(function(character)
                local humanoid = character:WaitForChild("Humanoid")
                local lastHealth = humanoid.Health
                humanoid.HealthChanged:Connect(function(newHealth)
                    if newHealth <= 0 and lastHealth > 0 then
                        if Enabled.KillSay then
                            local assistPlayers = {}
                            
                            for _, p in pairs(Players:GetPlayers()) do
                                if p ~= LocalPlayer and p ~= player and p.Character then
                                    local dist = (character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                                    if dist < 30 then
                                        table.insert(assistPlayers, p)
                                    end
                                end
                            end
                            
                            if #assistPlayers > 0 and Enabled.KillSayAssist then
                                sendKillSayMessage("Assist", player.Name)
                            elseif Enabled.KillSayFinish then
                                sendKillSayMessage("Finish", player.Name)
                            elseif Enabled.KillSay then
                                sendKillSayMessage("Normal", player.Name)
                            end
                        end
                    end
                    lastHealth = newHealth
                end)
            end)
        end
    end)
end

