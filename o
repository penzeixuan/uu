-- 静默自瞄：Hook namecall
local silentAimHook = nil
local function setupSilentAimHook()
    if silentAimHook then return end
    
    local mt = getrawmetatable(game)
    local oldNamecall = mt.__namecall
    setreadonly(mt, false)
    
    silentAimHook = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if method == "FireServer" or method == "InvokeServer" then
            if Enabled.SilentAim and silentAimTarget then
                -- 处理远程事件参数
                if typeof(args[1]) == "table" then
                    if args[1].hit or args[1].Hit or args[1].target then
                        -- 命中率检查
                        if SilentAimSettings.HitChance < 100 then
                            if math.random(1, 100) > SilentAimSettings.HitChance then
                                return oldNamecall(self, ...)
                            end
                        end
                        
                        -- 修改命中位置
                        local targetPos = silentAimTarget.Position
                        if SilentAimSettings.Prediction > 0 then
                            targetPos = targetPos + (silentAimTarget.AssemblyLinearVelocity * SilentAimSettings.Prediction)
                        end
                        
                        if args[1].hit then args[1].hit = targetPos end
                        if args[1].Hit then args[1].Hit = targetPos end
                        if args[1].target then args[1].target = targetPos end
                    end
                elseif typeof(args[1]) == "Vector3" then
                    -- 直接修改Vector3参数
                    if SilentAimSettings.HitChance < 100 then
                        if math.random(1, 100) > SilentAimSettings.HitChance then
                            return oldNamecall(self, ...)
                        end
                    end
                    
                    local targetPos = silentAimTarget.Position
                    if SilentAimSettings.Prediction > 0 then
                        targetPos = targetPos + (silentAimTarget.AssemblyLinearVelocity * SilentAimSettings.Prediction)
                    end
                    args[1] = targetPos
                end
            end
        end
        
        return oldNamecall(self, ...)
    end)
    
    mt.__namecall = silentAimHook
    setreadonly(mt, true)
end

