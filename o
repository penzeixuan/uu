task.spawn(function()
    while true do
        task.wait(SecurityConfig.CheckInterval)
        
        -- 检查调试工具
        if SecurityModule:CheckDebugTools() then
            warn("[Security] 检测到调试工具，执行保护清理")
            CleanupAllFeatures()
            
            -- 隐藏而不是销毁，避免引起注意
            pcall(function()
                local coreGui = game:GetService("CoreGui")
                for _, v in pairs(coreGui:GetChildren()) do
                    if v:IsA("ScreenGui") and v.Name:match("NEVERLOSE") then
                        v.Enabled = false
                    end
                end
            end)
            return
        end
        
        -- 检查函数是否被Hook
        for _, funcName in ipairs(SecurityConfig.ProtectedFuncs) do
            if SecurityModule:CheckFunctionIntegrity(funcName) then
                warn("[Security] 检测到函数被Hook: " .. funcName)
                
                -- 先尝试恢复
                if not SecurityModule:RestoreFunction(funcName) then
                    CleanupAllFeatures()
                    pcall(function()
                        for _, v in pairs(game:GetService("CoreGui"):GetChildren()) do
                            if v:IsA("ScreenGui") then
                                v.Enabled = false
                            end
                        end
                    end)
                    return
                end
            end
        end
    end
end)

