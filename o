local function GetDisguisedName()
    local prefixes = {"System", "Core", "Player", "UI", "App", "Service", "Roblox", "Client", "Input", "Render"}
    local suffixes = {"Module", "Handler", "Manager", "Service", "Component", "Helper", "Utils", "Bridge", "State", "Cache"}
