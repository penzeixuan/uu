local function DisguiseGui(gui)
    if not gui then return end
    local newName = GetDisguisedName()
    gui.Name = newName
    table.insert(ProtectedGuiList, gui)
    DisguisedNames[gui] = newName
    
    if protectgui then
        pcall(function() protectgui(gui) end)
    end
    
    return newName
end

