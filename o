local function ValidateKey(key)
    if not key or key == "" then
        return false, "卡密不能为空"
    end
    
    -- 检查是否已使用
    if KEY_SYSTEM.UsedKeys[key] then
        return false, "此卡密已被使用"
    end
    
    -- 验证卡密是否在有效库中
    for _, validKey in ipairs(KEY_SYSTEM.ValidKeys) do
        if key == validKey then
            KEY_SYSTEM.UsedKeys[key] = true
            KEY_SYSTEM.CurrentKey = key
            return true, "验证成功！"
        end
    end
    
    return false, "卡密无效，请检查后重试"
end

