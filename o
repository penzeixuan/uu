-- 获取自瞄目标
local function getAimbotTarget(camera, mouseOrigin)
    local closestPlayer = nil
    local closestDist = math.huge

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end

        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
        local head = player.Character:FindFirstChild("Head")

        if not humanoid or not rootPart or humanoid.Health <= 0 then continue end

        if Enabled.AimbotTeamCheck and player.Team == LocalPlayer.Team then continue end

        local targetPos = head and head.Position or (rootPart.Position + Vector3.new(0, 2, 0))
        local screenPos, isVisible = camera:WorldToViewportPoint(targetPos)

        if not isVisible then continue end

        -- 墙体检测：如果不穿墙且射线被阻挡则跳过
        if not Enabled.AimbotWallCheck then
            local origin = camera.CFrame.Position
            local direction = (targetPos - origin).Unit
            local raycastParams = RaycastParams.new()
            raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
            raycastParams.FilterType = Enum.RaycastFilterType.Exclude
            local result = workspace:Raycast(origin, direction * (targetPos - origin).Magnitude, raycastParams)
            if result and result.Instance and not result.Instance:IsDescendantOf(player.Character) then
                continue
            end
        end

        local dist = (Vector2.new(screenPos.X, screenPos.Y) - mouseOrigin).Magnitude
        if dist < Settings.AimbotFOV and dist < closestDist then
            closestDist = dist
            closestPlayer = player
        end
    end

    return closestPlayer
end

-- 静默自瞄：获取最近目标
local function getSilentAimTarget(camera, mousePos)
    local closestPlayer = nil
    local closestDist = math.huge
    local closestPart = nil
    
    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer or not player.Character then continue end
        
        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        
        -- 团队检查
        if SilentAimSettings.TeamCheck then
            if player.Team == LocalPlayer.Team then continue end
        end
        
        local targetPart = player.Character:FindFirstChild(SilentAimSettings.TargetPart)
        if not targetPart then
            targetPart = player.Character:FindFirstChild("Head")
        end
        if not targetPart then continue end
        
        -- 距离检查
        local distance = (targetPart.Position - camera.CFrame.Position).Magnitude
        if distance > SilentAimSettings.MaxDistance then continue end
        
        -- 可见性检查
        if SilentAimSettings.VisibleCheck then
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
            rayParams.FilterType = Enum.RaycastFilterType.Exclude
            
            local direction = (targetPart.Position - camera.CFrame.Position).Unit * distance
            local rayResult = workspace:Raycast(camera.CFrame.Position, direction, rayParams)
            
            if rayResult and rayResult.Instance then
                if not rayResult.Instance:IsDescendantOf(player.Character) then
                    continue
                end
            end
        end
        
        -- 预测位置
        local predictedPos = targetPart.Position
        if SilentAimSettings.Prediction > 0 then
            local velocity = targetPart.AssemblyLinearVelocity
            predictedPos = targetPart.Position + (velocity * SilentAimSettings.Prediction)
        end
        
        local screenPos, onScreen = camera:WorldToViewportPoint(predictedPos)
        if not onScreen then continue end
        
        local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
        if dist < SilentAimSettings.FOVRadius and dist < closestDist then
            closestDist = dist
            closestPlayer = player
            closestPart = targetPart
        end
    end
    
    return closestPlayer, closestPart
end

