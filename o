flyConnection = RunService.RenderStepped:Connect(function()
    if Enabled.Fly and flyVelocity and flyGyro and LocalPlayer.Character then
        local camera = workspace.CurrentCamera
        local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end

        flyGyro.CFrame = camera.CFrame

        local moveVector = Vector3.new(0, 0, 0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveVector = moveVector + camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveVector = moveVector - camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveVector = moveVector - camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveVector = moveVector + camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            moveVector = moveVector + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
            moveVector = moveVector - Vector3.new(0, 1, 0)
        end

        flyVelocity.Velocity = moveVector * Settings.FlySpeed
    end
end)

RunService.RenderStepped:Connect(function()
    local camera = workspace.CurrentCamera
    if camera then
        FOVCircle.Position = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
        FOVCircle.Radius = Settings.AimbotFOV
        FOVCircle.Visible = Enabled.Aimbot
    end

    if Enabled.Aimbot and aimbotActive then
        local mouseOrigin = UserInputService:GetMouseLocation()
        local target = getAimbotTarget(camera, mouseOrigin)
        if target then
            local head = target.Character:FindFirstChild("Head")
            if head then
                local targetPos = head.Position
                local screenPos = camera:WorldToViewportPoint(targetPos)

                local delta = Vector2.new(screenPos.X, screenPos.Y) - mouseOrigin
                local alpha = 1 / Settings.AimbotSmoothness
                local moveBy = delta * alpha

                pcall(function()
                    mousemoverel(moveBy.X, moveBy.Y)
                end)
            end
        end
    end
    
    -- 静默自瞄更新
    if Enabled.SilentAim then
        local mousePos = UserInputService:GetMouseLocation()
        silentAimDrawing.Position = mousePos
        silentAimDrawing.Radius = SilentAimSettings.FOVRadius
        silentAimDrawing.Visible = SilentAimSettings.FOVVisible
        
        local target, targetPart = getSilentAimTarget(camera, mousePos)
        silentAimTarget = targetPart
        
        if target and targetPart then
            local screenPos = camera:WorldToViewportPoint(targetPart.Position)
            targetIndicator.Position = Vector2.new(screenPos.X, screenPos.Y)
            targetIndicator.Visible = SilentAimSettings.ShowTarget
        else
            targetIndicator.Visible = false
        end
    else
        silentAimDrawing.Visible = false
        targetIndicator.Visible = false
        silentAimTarget = nil
    end

    if Enabled.ESPBox or Enabled.ESPName or Enabled.ESPDistance or Enabled.ESPHealth or Enabled.ESPLookDir then
        for _, player in pairs(Players:GetPlayers()) do
            if player == LocalPlayer or not player.Character then continue end

            if Enabled.ESPTeamCheck and player.Team == LocalPlayer.Team then continue end

            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
            local head = player.Character:FindFirstChild("Head")

            if not humanoid or not rootPart then continue end

            if not espDrawings[player] then
                espDrawings[player] = createESPDrawings()
            end

            local playerData = espDrawings[player]
            local rootPos = rootPart.Position
            local headPos = head and head.Position or (rootPos + Vector3.new(0, 2, 0))

            local headScreen, headVisible = camera:WorldToViewportPoint(headPos)
            local rootScreen, rootVisible = camera:WorldToViewportPoint(rootPos)

            local isVisible = headVisible or rootVisible

            for _, drawing in pairs(playerData) do
                drawing.Visible = false
            end

            if not isVisible then continue end

            local centerPos = Vector2.new(headScreen.X, headScreen.Y)
            local distance = (camera.CFrame.Position - rootPos).Magnitude

            local boxHeight = math.clamp(3000 / distance, 30, 300)
            local boxWidth = boxHeight * 0.6
            local boxTop = centerPos.Y - boxHeight * 0.5
            local boxBottom = centerPos.Y + boxHeight * 0.3

            if Enabled.ESPBox then
                playerData.boxOutline.Visible = true
                playerData.boxOutline.Color = Color3.new(0, 0, 0)
                playerData.boxOutline.Thickness = 3
                playerData.boxOutline.Size = Vector2.new(boxWidth, boxHeight)
                playerData.boxOutline.Position = Vector2.new(centerPos.X - boxWidth / 2, boxTop)
                playerData.boxOutline.Filled = false

                playerData.box.Visible = true
                playerData.box.Color = Color3.fromRGB(255, 50, 50)
                playerData.box.Thickness = 1
                playerData.box.Size = Vector2.new(boxWidth, boxHeight)
                playerData.box.Position = Vector2.new(centerPos.X - boxWidth / 2, boxTop)
                playerData.box.Filled = false
            end

            if Enabled.ESPName then
                playerData.nameLabel.Visible = true
                playerData.nameLabel.Text = player.Name
                playerData.nameLabel.Size = 14
                playerData.nameLabel.Center = true
                playerData.nameLabel.Outline = true
                playerData.nameLabel.Color = Color3.new(1, 1, 1)
                playerData.nameLabel.Position = Vector2.new(centerPos.X, boxTop - 20)
            end

            if Enabled.ESPDistance then
                playerData.distLabel.Visible = true
                playerData.distLabel.Text = string.format("%.1f studs", distance)
                playerData.distLabel.Size = 12
                playerData.distLabel.Center = true
                playerData.distLabel.Outline = true
                playerData.distLabel.Color = Color3.new(1, 1, 1)
                playerData.distLabel.Position = Vector2.new(centerPos.X, boxBottom + 5)
            end

            if Enabled.ESPHealth then
                local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
                local healthHeight = boxHeight * healthPercent

                playerData.healthBarBg.Visible = true
                playerData.healthBarBg.Size = Vector2.new(8, boxHeight)
                playerData.healthBarBg.Position = Vector2.new(centerPos.X - boxWidth / 2 - 15, boxTop)
                playerData.healthBarBg.Color = Color3.fromRGB(30, 30, 30)
                playerData.healthBarBg.Filled = true

                playerData.healthBarFill.Visible = true
                playerData.healthBarFill.Size = Vector2.new(8, healthHeight)
                playerData.healthBarFill.Position = Vector2.new(centerPos.X - boxWidth / 2 - 15, boxBottom - healthHeight)
                playerData.healthBarFill.Color = Color3.fromRGB(0, 255, 0)
                playerData.healthBarFill.Filled = true
            end

            if Enabled.ESPLookDir and head then
                local lookAt = head.CFrame.LookVector * 10
                local lookPos = headPos + lookAt
                local lookScreen, lookVisible = camera:WorldToViewportPoint(lookPos)

                if lookVisible then
                    playerData.lookDirection.Visible = true
                    playerData.lookDirection.From = Vector2.new(headScreen.X, headScreen.Y)
                    playerData.lookDirection.To = Vector2.new(lookScreen.X, lookScreen.Y)
                    playerData.lookDirection.Color = Color3.fromRGB(255, 255, 0)
                    playerData.lookDirection.Thickness = 2
                end
            end
        end
    end
    
    -- 战斗功能处理
    if CombatSettings.autoKill or CombatSettings.tpPlayer then
        local targetPlayer = nil
        
        if CombatSettings.targetPlayer == "ALL" then
            local closestDist = math.huge
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
                    if rootPart and LocalPlayer.Character then
                        local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if myRoot then
                            local dist = (myRoot.Position - rootPart.Position).Magnitude
                            if dist < closestDist then
                                closestDist = dist
                                targetPlayer = player
                            end
                        end
                    end
                end
            end
        else
            targetPlayer = Players:FindFirstChild(CombatSettings.targetPlayer)
        end
        
        if targetPlayer and targetPlayer.Character then
            local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot and LocalPlayer.Character then
                local myRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    if CombatSettings.tpPlayer then
                        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, -Settings.TPDistance)
                    end
                end
            end
        end
    end
    
    -- 闪现功能
    if CombatSettings.blink then
        if LocalPlayer.Character then
            local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if rootPart then
                    if not CombatData.originalPosition then
                        CombatData.originalPosition = rootPart.Position
                        CombatData.blinkStartTime = tick()
                    end
                    
                    if tick() - CombatData.blinkStartTime > 0.3 then
                        local closestEnemy = nil
                        local closestDist = math.huge
                        
                        for _, player in pairs(Players:GetPlayers()) do
                            if player ~= LocalPlayer and player.Character then
                                local enemyRoot = player.Character:FindFirstChild("HumanoidRootPart")
                                if enemyRoot then
                                    local dist = (rootPart.Position - enemyRoot.Position).Magnitude
                                    if dist < closestDist and dist < 50 then
                                        closestDist = dist
                                        closestEnemy = enemyRoot
                                    end
                                end
                            end
                        end
                        
                        if closestEnemy then
                            rootPart.CFrame = closestEnemy.CFrame * CFrame.new(0, 0, -2)
                            CombatData.originalPosition = nil
                        end
                    end
                end
            end
        end
    end
    
    -- 自动护甲
    if CombatSettings.autoVest then
        if workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Entities") then
            local itemFolder = workspace.Game.Entities:FindFirstChild("ItemPickup")
            if itemFolder then
                for _, model in pairs(itemFolder:GetChildren()) do
                    for _, v in pairs(model:GetChildren()) do
                        if v:IsA("BasePart") then
                            local prompt = v:FindFirstChildOfClass("ProximityPrompt")
                            if prompt and (prompt.ObjectText == "Vest" or prompt.ObjectText == "Body Armor") then
                                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                                    LocalPlayer.Character.HumanoidRootPart.CFrame = v.CFrame
                                    prompt.RequiresLineOfSight = false
                                    prompt.HoldDuration = 0
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- 自动回血
    if CombatSettings.autoHealth then
        if workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Entities") then
            local itemFolder = workspace.Game.Entities:FindFirstChild("ItemPickup")
            if itemFolder then
                for _, model in pairs(itemFolder:GetChildren()) do
                    for _, v in pairs(model:GetChildren()) do
                        if v:IsA("BasePart") then
                            local prompt = v:FindFirstChildOfClass("ProximityPrompt")
                            if prompt and (prompt.ObjectText == "Health Pack" or prompt.ObjectText == "Medkit") then
                                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                                    LocalPlayer.Character.HumanoidRootPart.CFrame = v.CFrame
                                    prompt.RequiresLineOfSight = false
                                    prompt.HoldDuration = 0
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- 自动口罩
    if CombatSettings.autoKZ then
        if workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Entities") then
            local itemFolder = workspace.Game.Entities:FindFirstChild("ItemPickup")
            if itemFolder then
                for _, model in pairs(itemFolder:GetChildren()) do
                    for _, v in pairs(model:GetChildren()) do
                        if v:IsA("BasePart") then
                            local prompt = v:FindFirstChildOfClass("ProximityPrompt")
                            if prompt and (prompt.ObjectText == "Gas Mask" or prompt.ObjectText == "Mask" or prompt.ObjectText == "KZ") then
                                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                                    LocalPlayer.Character.HumanoidRootPart.CFrame = v.CFrame
                                    prompt.RequiresLineOfSight = false
                                    prompt.HoldDuration = 0
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)

