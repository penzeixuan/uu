-- ====== 调试工具检测增强 ======
SecurityConfig.DebugTools = {
    "Dex", "Explorer", "ServerSidebar", "DebugTools", "Output",
    "SimpleSpy", "Kavo", "Rayfield", "DarkDex", "Sirhurt",
    "Sentinel", "Verex", "Oxygen", "Ronix", "Delta"
}

SecurityConfig.HookedFunctions = {}

function SecurityModule:CheckDebugTools()
    local env = getgenv()
    local globalEnv = _G
    
    for _, tool in ipairs(SecurityConfig.DebugTools) do
        if env[tool] or globalEnv[tool] then
            SecurityConfig.SuspiciousActivity = true
            return true
        end
    end
    
    -- 检查执行器特征
    local executorSignatures = {
        "Synapse", "ScriptWare", "Oxygen", "Celery", "Fluxus",
        "Hydrogen", "Delta", "Codex", "Arceus", "Ace"
    }
    
    for _, sig in ipairs(executorSignatures) do
        if env[sig] or (env.identifyExecutor and string.find(tostring(env.identifyExecutor()), sig, 1, true)) then
            SecurityConfig.SuspiciousActivity = true
            return true
        end
    end
    
    return false
end

-- ====== 函数完整性保护 ======
SecurityConfig.ProtectedFuncs = {
    "print", "warn", "error", "tick", "elapsed",
    "Instance", "Vector3", "CFrame", "UDim2",
    "spawn", "delay", "wait", "task"
}

function SecurityModule:SaveOriginalFunctions()
    local env = getfenv(0)
    for _, funcName in ipairs(SecurityConfig.ProtectedFuncs) do
        local original = env[funcName]
        if original then
            SecurityConfig.OriginalFunctions[funcName] = original
        end
    end
end

function SecurityModule:CheckFunctionIntegrity(funcName)
    local current = getfenv(0)[funcName]
    local original = SecurityConfig.OriginalFunctions[funcName]
    
    if not original then
        return false
    end
    
    return current ~= original
end

function SecurityModule:RestoreFunction(funcName)
    local original = SecurityConfig.OriginalFunctions[funcName]
    if original then
        getfenv(0)[funcName] = original
        return true
    end
    return false
end

-- ====== GUI隐蔽系统 ======
function SecurityModule:CreateDisguisedName()
    local prefixes = {"System", "Core", "Player", "UI", "App", "Service", "Roblox", "Client"}
    local suffixes = {"Module", "Handler", "Manager", "Service", "Component", "Helper", "Utils", "Bridge"}
    
    return prefixes[math.random(#prefixes)] .. suffixes[math.random(#suffixes)] .. "_" .. string.sub(GenerateRandomID(), 1, 6)
end

function SecurityModule:DisguiseScreenGui(gui)
    local disguiseName = self:CreateDisguisedName()
    gui.Name = disguiseName
    
    -- 设置为合理的DisplayOrder避免检测
    gui.DisplayOrder = math.random(1, 10)
    gui.ResetOnSpawn = false
    
    -- 启用保护
    if protectgui then
        pcall(function() protectgui(gui) end)
    end
    
    return disguiseName
end

-- ====== 心跳监控和自动恢复 ======
function SecurityModule:StartHeartbeat()
    task.spawn(function()
        while SecurityConfig.AntiDetectionEnabled do
            SecurityConfig.HeartbeatCount = SecurityConfig.HeartbeatCount + 1
            
            -- 检查调试工具
            if SecurityModule:CheckDebugTools() then
                SecurityModule:HandleSuspiciousActivity("Debug tool detected")
            end
            
            -- 检查函数完整性
            if SecurityConfig.HeartbeatCount % 10 == 0 then
                for _, funcName in ipairs(SecurityConfig.ProtectedFuncs) do
                    if SecurityModule:CheckFunctionIntegrity(funcName) then
                        SecurityModule:RestoreFunction(funcName)
                    end
                end
            end
            
            -- 检查GUI存活
            if SecurityConfig.HeartbeatCount % 5 == 0 then
                SecurityModule:CheckGuiIntegrity()
            end
            
            SecurityConfig.LastCheckTime = tick()
            task.wait(SecurityConfig.CheckInterval / 10)
        end
    end)
end

function SecurityModule:CheckGuiIntegrity()
    local coreGui = game:GetService("CoreGui")
    local playerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
    
    -- 检查关键GUI是否存活
    for name, gui in pairs(SecurityConfig.ProtectedInstances) do
        if gui and not gui.Parent then
            -- GUI被删除，尝试恢复
            pcall(function()
                gui.Parent = coreGui:FindFirstChild("NEVERLOSE") or playerGui
            end)
        end
    end
end

function SecurityModule:HandleSuspiciousActivity(reason)
    warn("[Security] Suspicious activity: " .. tostring(reason))
    
    -- 尝试隐藏
    pcall(function()
        for name, gui in pairs(SecurityConfig.ProtectedInstances) do
            if gui and gui:IsA("ScreenGui") then
                gui.Enabled = false
                task.wait(0.5)
                gui.Enabled = true
            end
        end
    end)
end

